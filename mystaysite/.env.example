# -----------------------------------------------------------------------------
# MyStaySite environment variables
# -----------------------------------------------------------------------------
# Copy to `.env.local` (for local dev) and add the production values to your
# hosting provider's dashboard (Vercel → Project → Settings → Environment
# Variables). NEVER commit real secrets.
# -----------------------------------------------------------------------------

# --- Forms ------------------------------------------------------------------
# Formspree endpoint the server-side API route forwards to. The public form
# ID is safe to check into the repo, but using an env var lets you rotate it
# without a code change if you ever get abused.
FORMSPREE_ENDPOINT=https://formspree.io/f/xeerjqzn

# --- Cloudflare Turnstile (optional but recommended) ------------------------
# Free, privacy-friendly CAPTCHA alternative to reCAPTCHA. GDPR-friendly
# (no cookies, no tracking).
#
# Setup (3 minutes):
#   1. Create an account at https://www.cloudflare.com (free)
#   2. Go to https://dash.cloudflare.com → Turnstile → Add site
#   3. Widget Mode: "Managed" (recommended) or "Invisible"
#   4. Add `mystaysite.com` and `localhost` to allowed hostnames
#   5. Paste the **Site Key** below (public, safe in client bundle)
#   6. Paste the **Secret Key** in TURNSTILE_SECRET_KEY (server-only)
#
# When both vars are set, the forms render the Turnstile widget and the
# server verifies every submission. When empty, the forms keep working
# without a CAPTCHA (honeypot + time guard + content checks still apply).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Microsoft Clarity (heatmaps + session recordings) ---------------------
# Clarity is a free, GDPR-capable analytics tool from Microsoft that gives
# heatmaps, session recordings, and user insights on top of GA4.
#
# Setup (2 minutes):
#   1. Go to https://clarity.microsoft.com and sign in (Microsoft / Google)
#   2. Click "Add new project"
#       - Project name: MyStaySite
#       - Website URL: https://mystaysite.com
#       - Category: Business services
#   3. On the "Install tracking code" screen, copy the **Project ID**
#      (10-char string, e.g. "abcd1234ef")
#   4. Paste it below
#
# The script loads only after the user grants ANALYTICS consent in the
# cookie banner. If this var is empty, nothing loads (safe no-op).
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# --- Privacy ----------------------------------------------------------------
# Random string used to salt hashed IPs in server logs (GDPR-friendlier).
# Generate with: openssl rand -hex 32
IP_HASH_SALT=change-me-to-a-random-string
